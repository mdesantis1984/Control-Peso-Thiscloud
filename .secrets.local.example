# ============================================
# SECRETS - Local Development
# ============================================
# NEVER COMMIT THIS FILE
# Copy from: .secrets.local.example

version: '3.8'

services:
  controlpeso-sqlserver:
    environment:
      - MSSQL_SA_PASSWORD=CHANGE_ME_SQL_PASSWORD_HERE

  controlpeso-web:
    environment:
      - SQLSERVER_SA_PASSWORD=CHANGE_ME_SQL_PASSWORD_HERE
      - Authentication__Google__ClientId=CHANGE_ME_GOOGLE_CLIENT_ID_HERE
      - Authentication__Google__ClientSecret=CHANGE_ME_GOOGLE_CLIENT_SECRET_HERE
      - Telegram__BotToken=CHANGE_ME_TELEGRAM_BOT_TOKEN_HERE
      - Telegram__ChatId=CHANGE_ME_TELEGRAM_CHAT_ID_HERE
