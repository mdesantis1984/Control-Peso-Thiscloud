@page "/changelog"
@page "/historial"

<PageTitle>@PageTitleText</PageTitle>

<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="robots" content="index, follow" />
</HeadContent>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4 mb-8">
    <MudPaper Elevation="2" Class="pa-6">
        <MudStack Spacing="4">
            @* Header *@
            <MudStack Row="true" Justify="Justify.SpaceBetween" Spacing="2" AlignItems="AlignItems.Center">
                <img src="/images/LogoControlPeso/og-image.png" alt="Control Peso Thiscloud Logo" style="width: 48px; height: 48px; border-radius: 8px;" />
                <MudText Typo="Typo.h3" Color="Color.Info">@Title</MudText>
                <MudSpacer />
                <MudTooltip Text="@LanguageSwitchTooltip">
                    <MudIconButton Icon="@Icons.Material.Filled.Translate"
                                   Color="Color.Secondary"
                                   OnClick="ToggleLanguage" />
                </MudTooltip>
            </MudStack>

            <MudDivider />

            <MudText>@IntroText</MudText>

            @* Unreleased / Planned Features *@
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Construction" Color="Color.Warning" />
                            <MudText Typo="Typo.h5">[@UnreleasedLabel]</MudText>
                        </MudStack>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.h6">@PlannedFeaturesTitle</MudText>
                    <MudList T="string" Dense="true">
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Language">@Feature1</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Dashboard">@Feature2</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.PhoneAndroid">@Feature3</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Email">@Feature4</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.FileDownload">@Feature5</MudListItem>
                        <MudListItem T="string" Icon="@Icons.Material.Filled.Notifications">@Feature6</MudListItem>
                    </MudList>
                </MudCardContent>
            </MudCard>

            @* Version Timeline *@
            <MudTimeline TimelineOrientation="TimelineOrientation.Vertical" TimelinePosition="TimelinePosition.Start">
                
                @* v1.3.0 - Current *@
                <MudTimelineItem Color="Color.Success" Size="Size.Large" Elevation="2">
                    <ItemOpposite>
                        <MudChip T="string" Color="Color.Success" Size="Size.Large">v1.3.0</MudChip>
                    </ItemOpposite>
                    <ItemContent>
                        <MudCard Elevation="0">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">v1.3.0 - February 25, 2026</MudText>
                                    <MudChip T="string" Icon="@Icons.Material.Filled.Star" Color="Color.Success" Size="Size.Small">@CurrentVersionLabel</MudChip>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@AddedLabel</MudText>
                                <MudList T="string" Dense="true">
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.CloudDone">@V130_Feature1</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Security">@V130_Feature2</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Search">@V130_Feature3</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Description">@V130_Feature4</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.RocketLaunch">@V130_Feature5</MudListItem>
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>

                @* v1.2.0 *@
                <MudTimelineItem Color="Color.Info" Elevation="1">
                    <ItemOpposite>
                        <MudChip T="string" Color="Color.Info">v1.2.0</MudChip>
                    </ItemOpposite>
                    <ItemContent>
                        <MudCard Elevation="0">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">v1.2.0 - February 15, 2026</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@AddedLabel</MudText>
                                <MudList T="string" Dense="true">
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Palette">@V120_Feature1</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.PhonelinkSetup">@V120_Feature2</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Language">@V120_Feature3</MudListItem>
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>

                @* v1.1.0 *@
                <MudTimelineItem Color="Color.Primary" Elevation="1">
                    <ItemOpposite>
                        <MudChip T="string" Color="Color.Primary">v1.1.0</MudChip>
                    </ItemOpposite>
                    <ItemContent>
                        <MudCard Elevation="0">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">v1.1.0 - February 1, 2026</MudText>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@AddedLabel</MudText>
                                <MudList T="string" Dense="true">
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.TrendingUp">@V110_Feature1</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.FilterAlt">@V110_Feature2</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Note">@V110_Feature3</MudListItem>
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>

                @* v1.0.0 - Initial Release *@
                <MudTimelineItem Color="Color.Tertiary" Size="Size.Large" Elevation="2">
                    <ItemOpposite>
                        <MudChip T="string" Color="Color.Tertiary" Size="Size.Large">v1.0.0</MudChip>
                    </ItemOpposite>
                    <ItemContent>
                        <MudCard Elevation="0">
                            <MudCardHeader>
                                <CardHeaderContent>
                                    <MudText Typo="Typo.h6">v1.0.0 - January 15, 2026</MudText>
                                    <MudChip T="string" Icon="@Icons.Material.Filled.Rocket" Color="Color.Tertiary" Size="Size.Small">@InitialReleaseLabel</MudChip>
                                </CardHeaderContent>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.subtitle2" Class="mb-2">@CoreFeaturesLabel</MudText>
                                <MudList T="string" Dense="true">
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Login">@V100_Feature1</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.MonitorWeight">@V100_Feature2</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Timeline">@V100_Feature3</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Palette">@V100_Feature4</MudListItem>
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Storage">@V100_Feature5</MudListItem>
                                </MudList>
                            </MudCardContent>
                        </MudCard>
                    </ItemContent>
                </MudTimelineItem>
            </MudTimeline>

            @* Semantic Versioning Explanation *@
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.Info">
                <MudText Typo="Typo.h6">@SemanticVersioningTitle</MudText>
                <MudText Typo="Typo.body2">@SemanticVersioningText</MudText>
                <MudStack Row="true" Spacing="2" Class="mt-2">
                    <MudChip T="string" Icon="@Icons.Material.Filled.ErrorOutline" Color="Color.Error" Size="Size.Small">MAJOR.0.0</MudChip>
                    <MudChip T="string" Icon="@Icons.Material.Filled.Add" Color="Color.Warning" Size="Size.Small">0.MINOR.0</MudChip>
                    <MudChip T="string" Icon="@Icons.Material.Filled.BugReport" Color="Color.Success" Size="Size.Small">0.0.PATCH</MudChip>
                </MudStack>
            </MudAlert>

            @* Support *@
            <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Icon="@Icons.Material.Filled.Support">
                <MudText Typo="Typo.h6">@SupportTitle</MudText>
                <MudText>@SupportText</MudText>
                <MudButton Href="https://github.com/mdesantis1984/Control-Peso-Thiscloud/issues"
                           Target="_blank"
                           StartIcon="@Icons.Material.Filled.BugReport"
                           Variant="Variant.Text"
                           Color="Color.Primary">
                    GitHub Issues
                </MudButton>
            </MudAlert>

            @* Footer *@
            <MudDivider />
            <MudText Typo="Typo.h6" Align="Align.Center" Color="Color.Primary">
                💪 @ThankYouText
            </MudText>
        </MudStack>
    </MudPaper>
</MudContainer>
