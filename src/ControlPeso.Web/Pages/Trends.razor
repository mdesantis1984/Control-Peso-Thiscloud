@page "/trends"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using ControlPeso.Application.DTOs
@using ControlPeso.Web.Components.Shared
@using MudBlazor

<PageTitle>@PageTitle</PageTitle>

<HeadContent>
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="canonical" href="https://controlpeso.thiscloud.com.ar/trends" />

    @* Open Graph *@
    <meta property="og:title" content="@OgTitle" />
    <meta property="og:description" content="@OgDescription" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://controlpeso.thiscloud.com.ar/trends" />
    <meta property="og:image" content="https://controlpeso.thiscloud.com.ar/images/og-image.png" />
</HeadContent>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h4" Class="mb-4">@TrendsTitle</MudText>

    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_logs.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Icon="@Icons.Material.Filled.Info" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-2">@NoDataTitle</MudText>
            <MudText Typo="Typo.body2">
                @NoDataMessage
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                Ve al <MudLink Href="/dashboard" Color="Color.Primary">@DashboardLink</MudLink> y registra tu primer peso.
            </MudText>
        </MudAlert>
    }
    else if (_logs.Count < 4)
    {
        <MudAlert Severity="Severity.Warning" Icon="@Icons.Material.Filled.Warning" Elevation="2" Class="mb-4">
            <MudText Typo="Typo.h6" Class="mb-2">@LimitedDataTitle</MudText>
            <MudText Typo="Typo.body2">
                @((MarkupString)GetLimitedDataMessage(_logs.Count))
            </MudText>
            <MudText Typo="Typo.body2" Class="mt-2">
                @LimitedDataSubMessage
            </MudText>
        </MudAlert>

        <!-- Mostrar estadísticas básicas para datos limitados -->
        <MudGrid>
            <MudItem xs="12" md="6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@CurrentStatsTitle</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@CurrentWeightLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2"><strong>@_currentWeight.ToString("F1") @KgUnit</strong></MudText></td>
                                </tr>
                                @if (_logs.Count > 1)
                                {
                                    <tr>
                                        <td><MudText Typo="Typo.body2">@FirstWeightLabel</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_logs.First().Weight.ToString("F1") @KgUnit</MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2">@ChangeLabel</MudText></td>
                                        <td><MudText Typo="Typo.body2" Color="@(_totalChange < 0 ? Color.Success : Color.Warning)">
                                            @(_totalChange > 0 ? "+" : "")@_totalChange.ToString("F1") @KgUnit
                                        </MudText></td>
                                    </tr>
                                    <tr>
                                        <td><MudText Typo="Typo.body2">@AverageLabel</MudText></td>
                                        <td><MudText Typo="Typo.body2">@_overallAverage.ToString("F1") @KgUnit</MudText></td>
                                    </tr>
                                }
                                <tr>
                                    <td><MudText Typo="Typo.body2">@TotalRecordsLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_logs.Count</MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <MudItem xs="12" md="6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@NextStepsTitle</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudList T="string" Dense="true">
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                <MudText Typo="Typo.body2">@NextStep1</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                <MudText Typo="Typo.body2">@NextStep2</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Check" IconColor="Color.Success">
                                <MudText Typo="Typo.body2">@NextStep3</MudText>
                            </MudListItem>
                            <MudListItem T="string" Icon="@Icons.Material.Filled.ShowChart" IconColor="Color.Primary">
                                <MudText Typo="Typo.body2">@GetNextStep4(4 - _logs.Count)</MudText>
                            </MudListItem>
                        </MudList>
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
    else
    {
        <MudGrid>
            <!-- Tarjetas de tendencias -->
            <MudItem xs="12" sm="6" md="3">
                <TrendCard Title="@Last7Days"
                           CurrentValue="@_last7DaysAvg"
                           PreviousValue="@_previous7DaysAvg"
                           Unit="@KgUnit"
                           Icon="@Icons.Material.Filled.CalendarToday"
                           IconColor="Color.Primary"
                           LowerIsBetter="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <TrendCard Title="@Last30Days"
                           CurrentValue="@_last30DaysAvg"
                           PreviousValue="@_previous30DaysAvg"
                           Unit="@KgUnit"
                           Icon="@Icons.Material.Filled.CalendarMonth"
                           IconColor="Color.Secondary"
                           LowerIsBetter="true" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <TrendCard Title="@TotalChange"
                           CurrentValue="@_totalChange"
                           PreviousValue="0"
                           Unit="@KgUnit"
                           Icon="@Icons.Material.Filled.ShowChart"
                           IconColor="Color.Tertiary"
                           ShowChange="false" />
            </MudItem>

            <MudItem xs="12" sm="6" md="3">
                <TrendCard Title="@OverallAverage"
                           CurrentValue="@_overallAverage"
                           PreviousValue="@_startingWeight"
                           Unit="@KgUnit"
                           Icon="@Icons.Material.Filled.Analytics"
                           IconColor="Color.Info"
                           LowerIsBetter="true" />
            </MudItem>

            <!-- Gráfico de evolución -->
            <MudItem xs="12">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@WeightEvolution90Days</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <WeightChart Data="@_logs" Title="@EvolutionLabel" />
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Estadísticas detalladas -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@StatisticsTitle</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudSimpleTable Dense="true">
                            <tbody>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@CurrentWeightLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2"><strong>@_currentWeight.ToString("F1") @KgUnit</strong></MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@StartingWeightLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_startingWeight?.ToString("F1") @KgUnit</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@MinWeightLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2" Color="Color.Success">@_minWeight.ToString("F1") @KgUnit</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@MaxWeightLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2" Color="Color.Warning">@_maxWeight.ToString("F1") @KgUnit</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@OverallAverageLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_overallAverage.ToString("F1") @KgUnit</MudText></td>
                                </tr>
                                <tr>
                                    <td><MudText Typo="Typo.body2">@TotalRecordsLabel</MudText></td>
                                    <td><MudText Typo="Typo.body2">@_logs.Count</MudText></td>
                                </tr>
                            </tbody>
                        </MudSimpleTable>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Proyección simple -->
            <MudItem xs="12" md="6">
                <MudCard Elevation="2">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <MudText Typo="Typo.h6">@ProjectionTitle</MudText>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (_projectedWeight.HasValue)
                        {
                            <MudText Typo="Typo.body1" Class="mb-2">
                                @ProjectionDescription
                            </MudText>
                            <MudText Typo="Typo.h4" Color="@GetProjectionColor()">
                                @_projectedWeight.Value.ToString("F1") @KgUnit
                            </MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
                                @GetEstimatedChange(_projectedChange)
                            </MudText>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @InsufficientDataProjection
                            </MudText>
                        }
                    </MudCardContent>
                </MudCard>
            </MudItem>
        </MudGrid>
    }
</MudContainer>
