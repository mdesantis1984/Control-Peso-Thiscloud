@page "/profile"
@attribute [Authorize]
@using Microsoft.AspNetCore.Authorization
@using ControlPeso.Domain.Enums
@using MudBlazor

<PageTitle>Profile - WeightTracker</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="pa-6">
    @if (_isLoading)
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
    else if (_user is null)
    {
        <MudAlert Severity="Severity.Error">No se pudo cargar el perfil del usuario.</MudAlert>
    }
    else
    {
        <MudStack Spacing="4">
            <!-- Header Section with Avatar, Name, and Save Button -->
            <MudPaper Elevation="2" Class="pa-6">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                    <!-- Left: Avatar and Name -->
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <!-- Avatar with Click to Change -->
                        <div style="position: relative; cursor: pointer;" @onclick="TriggerFileInput">
                            @{
                                var avatarUrl = GetAvatarUrl();
                            }
                            @if (!string.IsNullOrWhiteSpace(avatarUrl))
                            {
                                <MudAvatar Size="Size.Large" Style="width: 80px; height: 80px;">
                                    <MudImage Src="@avatarUrl" Alt="@_user.Name" />
                                </MudAvatar>
                            }
                            else
                            {
                                <MudAvatar Color="Color.Primary" Size="Size.Large" Style="width: 80px; height: 80px; font-size: 32px;">
                                    @_user.Name[0]
                                </MudAvatar>
                            }
                            <MudTooltip Text="Click to change photo">
                                <MudIcon Icon="@Icons.Material.Filled.CameraAlt" 
                                         Style="position: absolute; bottom: 0; right: 0; background: var(--mud-palette-primary); border-radius: 50%; padding: 4px; color: white;" 
                                         Size="Size.Small" />
                            </MudTooltip>
                        </div>

                        <!-- Hidden File Input -->
                        <InputFile id="avatar-file-input" OnChange="OnPhotoSelectedAsync" accept="image/*" hidden />

                        <!-- Name and Member Since -->
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h5">@_user.Name</MudText>
                            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                                <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" />
                                <MudText Typo="Typo.caption">
                                    Member since @_user.MemberSince.ToString("MMMM yyyy")
                                </MudText>
                            </MudStack>
                        </MudStack>
                    </MudStack>

                    <!-- Right: Save Changes Button -->
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="SaveChanges"
                               Disabled="@_isSaving"
                               StartIcon="@Icons.Material.Filled.Save">
                        @if (_isSaving)
                        {
                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            <span>SAVING...</span>
                        }
                        else
                        {
                            <span>SAVE CHANGES</span>
                        }
                    </MudButton>
                </MudStack>
            </MudPaper>

        <!-- Stats Cards Section -->
        <MudGrid Spacing="3">
            <!-- Starting Weight -->
            <MudItem xs="12" md="4">
                <MudPaper Elevation="2" Class="pa-4">
                    <MudStack>
                        <MudText Typo="Typo.overline">STARTING WEIGHT</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                            <MudText Typo="Typo.h4">
                                @if (_stats?.StartingWeight.HasValue == true)
                                {
                                    @_stats.StartingWeight.Value.ToString("F1")
                                }
                                else if (_user.StartingWeight.HasValue)
                                {
                                    @_user.StartingWeight.Value.ToString("F1")
                                }
                                else
                                {
                                    <span>--</span>
                                }
                            </MudText>
                            <MudText Typo="Typo.body2">kg</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

            <!-- Current Weight -->
            <MudItem xs="12" md="4">
                <MudPaper Elevation="2" Class="pa-4" Style="background: var(--mud-palette-primary);">
                    <MudStack>
                        <MudText Typo="Typo.overline" Style="color: white;">CURRENT WEIGHT</MudText>
                        <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                            <MudText Typo="Typo.h4" Style="color: white;">
                                @if (_stats?.CurrentWeight.HasValue == true)
                                {
                                    @_stats.CurrentWeight.Value.ToString("F1")
                                }
                                else
                                {
                                    <span>--</span>
                                }
                            </MudText>
                            <MudText Typo="Typo.body2" Style="color: white;">kg</MudText>
                        </MudStack>
                    </MudStack>
                </MudPaper>
            </MudItem>

                <!-- Total Loss -->
                <MudItem xs="12" md="4">
                    <MudPaper Elevation="2" Class="pa-4">
                        <MudStack>
                            <MudText Typo="Typo.overline" Color="Color.Success">TOTAL LOSS</MudText>
                            <MudStack Row="true" AlignItems="AlignItems.End" Spacing="1">
                                <MudText Typo="Typo.h4" Color="Color.Success">
                                    @if (_stats?.TotalChange.HasValue == true)
                                    {
                                        @_stats.TotalChange.Value.ToString("F1")
                                    }
                                    else
                                    {
                                        <span>--</span>
                                    }
                                </MudText>
                                <MudText Typo="Typo.body2" Color="Color.Success">kg</MudText>
                            </MudStack>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>

        <!-- Two Column Layout: Personal Details + Account Settings -->
        <MudGrid Spacing="4">
            <!-- Left Column: Personal Details -->
            <MudItem xs="12" md="7">
                <MudCard>
                    <MudCardHeader>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudIcon Icon="@Icons.Material.Filled.Person" />
                            <MudText Typo="Typo.h6">Personal Details</MudText>
                        </MudStack>
                    </MudCardHeader>
                    <MudCardContent>

                                <MudStack Spacing="3">
                                    <!-- Name Field -->
                                    <MudTextField Label="Name*"
                                                  @bind-Value="_name"
                                                  Required="true"
                                                  RequiredError="Name is required"
                                                  MaxLength="200"
                                                  Variant="Variant.Outlined" />

                                    <!-- Height Field -->
                                    <MudNumericField Label="Height*"
                                                     @bind-Value="_height"
                                                     Required="true"
                                                     RequiredError="Height is required"
                                                     Min="50"
                                                     Max="300"
                                                     Variant="Variant.Outlined"
                                                     Adornment="Adornment.End"
                                                     AdornmentText="cm" />

                                    <!-- Unit System Select -->
                                    <MudSelect Label="Unit System"
                                               T="UnitSystem"
                                               @bind-Value="_unitSystem"
                                               Variant="Variant.Outlined">
                                        <MudSelectItem T="UnitSystem" Value="UnitSystem.Metric">Metric (kg, cm)</MudSelectItem>
                                        <MudSelectItem T="UnitSystem" Value="UnitSystem.Imperial">Imperial (lb, in)</MudSelectItem>
                                    </MudSelect>

                                    <!-- Date of Birth -->
                                    <MudDatePicker Label="Date of Birth"
                                                   @bind-Date="_dateOfBirth"
                                                   MaxDate="DateTime.Today"
                                                   Editable="true"
                                                   Variant="Variant.Outlined"
                                                   DateFormat="MM/dd/yyyy" />

                                    <!-- Goal Weight -->
                                    <MudNumericField Label="Goal Weight"
                                                     @bind-Value="_goalWeight"
                                                     Min="20"
                                                     Max="500"
                                                     Variant="Variant.Outlined"
                                                     Adornment="Adornment.End"
                                                     AdornmentText="kg" />

                                    <!-- Language Select -->
                                    <MudSelect Label="Language"
                                               T="string"
                                               @bind-Value="_language"
                                               Variant="Variant.Outlined">
                                        <MudSelectItem T="string" Value="@("es")">Español</MudSelectItem>
                                        <MudSelectItem T="string" Value="@("en")">English</MudSelectItem>
                                    </MudSelect>

                                    <!-- Dark Mode Switch -->
                                    <MudSwitch T="bool" 
                                               Value="@DarkMode" 
                                               ValueChanged="@OnDarkModeChanged" 
                                               Color="Color.Primary"
                                               Label="Dark Mode" />

                                    <!-- Notifications Switch -->
                                    <MudSwitch T="bool" 
                                               Value="@NotificationsEnabled" 
                                               ValueChanged="@OnNotificationsEnabledChanged" 
                                               Color="Color.Primary"
                                               Label="Notifications" />
                                </MudStack>
                            </MudCardContent>
                        </MudCard>
                    </MudItem>

                            <!-- Right Column: Account Settings -->
                            <MudItem xs="12" md="5">
                                <MudCard>
                                    <MudCardHeader>
                                        <MudStack Row="true" Spacing="2">
                                            <MudIcon Icon="@Icons.Material.Filled.Settings" />
                                            <MudText Typo="Typo.h6">Account Settings</MudText>
                                        </MudStack>
                                    </MudCardHeader>
                                    <MudCardContent>
                                        <MudStack Spacing="3">
                                            <!-- Email Address (Read-only) -->
                                            <div>
                                                <MudText Typo="Typo.caption">EMAIL ADDRESS</MudText>
                                                <MudText Typo="Typo.body1">@_user.Email</MudText>
                                            </div>

                                            <MudDivider />

                                            <!-- Sign Out Button -->
                                            <MudButton Variant="Variant.Outlined"
                                                       FullWidth="true"
                                                       StartIcon="@Icons.Material.Filled.Logout"
                                                       OnClick="SignOut">
                                                Sign Out
                                            </MudButton>

                                            <!-- Delete Account Button -->
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Error"
                                                       FullWidth="true"
                                                       StartIcon="@Icons.Material.Filled.Delete"
                                                       OnClick="OpenDeleteAccountDialog">
                                                Delete Account
                                            </MudButton>
                                        </MudStack>
                                    </MudCardContent>
                                </MudCard>
                            </MudItem>
                        </MudGrid>
                    </MudStack>
                }
            </MudContainer>
