<!DOCTYPE html>
<html lang="es-AR">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Control Peso Thiscloud - Aplicación web para seguimiento y control de peso corporal. Registro diario, gráficos de tendencia, estadísticas y análisis de evolución." />
    <meta name="keywords" content="control peso, seguimiento peso, dieta, salud, fitness, peso corporal, IMC, pérdida de peso" />
    <meta name="author" content="Thiscloud Services" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#594AE2" />

    @* Open Graph / Facebook *@
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://controlpeso.thiscloud.com.ar/" />
    <meta property="og:title" content="Control Peso Thiscloud - Seguimiento de Peso Corporal" />
    <meta property="og:description" content="Aplicación web para seguimiento y control de peso corporal. Registro diario, gráficos de tendencia, estadísticas y análisis." />
    <meta property="og:image" content="https://controlpeso.thiscloud.com.ar/images/og-image.png" />
    <meta property="og:locale" content="es_AR" />

    @* Twitter *@
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://controlpeso.thiscloud.com.ar/" />
    <meta name="twitter:title" content="Control Peso Thiscloud" />
    <meta name="twitter:description" content="Seguimiento y control de peso corporal. Registro diario, gráficos y estadísticas." />
    <meta name="twitter:image" content="https://controlpeso.thiscloud.com.ar/images/og-image.png" />

    <base href="/" />
    @* MudBlazor CSS (debe ir PRIMERO para que no haya cascading conflicts) *@
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />

    @* Cropper.js CSS for ImageCropperDialog (local bundle) *@
    <link href="lib/cropperjs/cropper.min.css" rel="stylesheet" />

    @* Custom CSS - Pixel Perfect Styles *@
    <link href="css/app.css" rel="stylesheet" />
    <link href="css/notifications.css" rel="stylesheet" />

    @* Storage JavaScript Interop *@
    <script src="js/storage.js"></script>

    @* Google Analytics 4 *@
    <script async src="https://www.googletagmanager.com/gtag/js?id=@googleAnalyticsMeasurementId"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '@googleAnalyticsMeasurementId', {
            'anonymize_ip': true,
            'cookie_flags': 'SameSite=Strict;Secure'
        });
    </script>

    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>

    @* MudBlazor JS *@
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>

    @* Cropper.js for ImageCropperDialog (local bundle) *@
    <script src="lib/cropperjs/cropper.min.js"></script>

    @* App JS *@
    <script src="js/app.js"></script>
    <script src="js/image-cropper.js"></script>
</body>

</html>
