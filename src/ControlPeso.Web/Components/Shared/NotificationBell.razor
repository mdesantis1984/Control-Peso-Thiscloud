@namespace ControlPeso.Web.Components.Shared

<AuthorizeView>
    <Authorized>
        <MudStack Row AlignItems="AlignItems.Center" Spacing="1" Class="@Class">
            <MudIconButton Icon="@Icons.Material.Filled.Notifications" 
                           Color="Color.Inherit"
                           OnClick="@ToggleNotificationPanel"
                           aria-label="@NotificationsAriaLabel" />
            @if (_unreadNotificationCount > 0)
            {
                <MudText Typo="Typo.caption" 
                         Style="background-color: #f44336; color: white; padding: 2px 6px; border-radius: 10px; font-size: 0.7rem; font-weight: 600; min-width: 20px; text-align: center;">
                    @_unreadNotificationCount
                </MudText>
            }
        </MudStack>

        <!-- Notification Panel Popover -->
        <NotificationPanel IsOpen="@_notificationPanelOpen" 
                           IsOpenChanged="@((bool open) => _notificationPanelOpen = open)"
                           OnUnreadCountChanged="@UpdateUnreadCount" />
    </Authorized>
</AuthorizeView>
