@using ControlPeso.Domain.Enums
@using MudBlazor
@namespace ControlPeso.Web.Components.Shared

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@DialogTitle</MudText>
    </TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">
            @ConfirmationMessage
        </MudText>

        <MudSelect 
            @bind-Value="_selectedStatus"
            Label="@NewStatusLabel"
            Variant="Variant.Outlined"
            Required="true">
            <MudSelectItem Value="@UserStatus.Active">@StatusActive</MudSelectItem>
            <MudSelectItem Value="@UserStatus.Inactive">@StatusInactive</MudSelectItem>
            <MudSelectItem Value="@UserStatus.Pending">@StatusPending</MudSelectItem>
        </MudSelect>

        <MudAlert Severity="@GetAlertSeverity()" Class="mt-4" Dense="true">
            <MudText Typo="Typo.body2">
                @GetAlertText()
            </MudText>
        </MudAlert>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Color="Color.Default">@CancelButton</MudButton>
        <MudButton 
            OnClick="Submit" 
            Color="@GetButtonColor()" 
            Variant="Variant.Filled"
            Disabled="@(_selectedStatus == CurrentStatus)">
            @ChangeStatusButton
        </MudButton>
    </DialogActions>
</MudDialog>
