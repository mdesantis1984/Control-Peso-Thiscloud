# Production Environment Variables Example
# Copy this file to .env and configure with real values
# .env is gitignored - never commit it!

# Application Port (external port exposed by Docker)
# Configure in NPM Plus to forward to: YOUR_SERVER_IP:APP_PORT
APP_PORT=8080

# SQL Server SA Password (REQUIRED)
# Must be strong: 8+ chars, mixed case, digits, special chars
SQLSERVER_SA_PASSWORD=YourProductionPassword@2026!

# Deploy Path (where application will be deployed on server)
# Default: /opt/app or /var/www/app
DEPLOY_PATH=/path/to/app
